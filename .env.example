# ============================================
# MESH — Environment variables (template)
# Copy to .env.local and fill in actual values.
# Most are optional in dev (the UI runs on mocks).
# ============================================

# --- Supabase (required for real backend) ---
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- AI providers (required to process nodes for real) ---
# Free tier accounts work fine to start.
JINA_API_KEY=                            # https://jina.ai
GROQ_API_KEY=                            # https://console.groq.com
DEEPSEEK_API_KEY=                        # https://platform.deepseek.com (Phase 5 only)

# --- Cache / queue (optional, falls back to no-op locally) ---
UPSTASH_REDIS_URL=                       # https://upstash.com — REST URL
UPSTASH_REDIS_TOKEN=

# --- Billing (optional, only needed for paid tiers) ---
STRIPE_SECRET_KEY=                       # sk_test_... for dev
STRIPE_WEBHOOK_SECRET=                   # whsec_... from `stripe listen`
STRIPE_PRICE_PERSONAL_MONTH=             # price_... €9/mo
STRIPE_PRICE_PERSONAL_YEAR=              # price_... €90/yr
STRIPE_PRICE_PRO_MONTH=                  # price_... €19/mo
STRIPE_PRICE_PRO_YEAR=                   # price_... €190/yr

# --- OAuth — Gmail connector ---
GOOGLE_CLIENT_ID=                        # console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:54321/functions/v1/connectors-gmail-auth?action=callback

# --- OAuth — future connectors ---
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# --- Public URLs ---
PUBLIC_WEB_URL=http://localhost:5173
PUBLIC_API_URL=http://127.0.0.1:54321/functions/v1

# --- Encryption (32+ char secret used by pgcrypto for OAuth tokens) ---
# Set on the DB with: ALTER DATABASE postgres SET app.mesh_token_key = '...';
TOKEN_ENCRYPTION_KEY=change-me-please-32-bytes-minimum

# --- Email (Resend, optional — falls back to console log) ---
RESEND_API_KEY=
RESEND_FROM=Mesh <hello@mesh.so>
RESEND_REPLY_TO=

# --- Observability (Edge Sentry tunnel, optional) ---
SENTRY_DSN_EDGE=
SENTRY_ENV=production
