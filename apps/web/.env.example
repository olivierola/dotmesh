# Web app env vars. Copy to apps/web/.env.local

# When 'true' (default), the dashboard uses in-memory mocks and works
# WITHOUT a backend. Flip to 'false' once Supabase + Edge Functions are running.
VITE_USE_MOCK=true

# Required if VITE_USE_MOCK=false:
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=http://127.0.0.1:54321/functions/v1

# --- Telemetry (optional) ---
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com
